{
  "imports": {
    "$fresh/": "https://denopkg.com/denoland/fresh@1.6.8/",
    "@deco/deco": "jsr:@deco/deco@1.84.7",
    "@deco/durable": "jsr:@deco/durable@^0.5.3",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.1.3",
    "@preact/signals-core": "https://esm.sh/@preact/signals-core@1.3.0",
    "@std/assert": "jsr:@std/assert@^1.0.2",
    "@std/crypto": "jsr:@std/crypto@^1.0.2",
    "@std/encoding": "jsr:@std/encoding@^1.0.1",
    "@std/fmt": "jsr:@std/fmt@^0.225.3",
    "@std/fs": "jsr:@std/fs@^1.0.1",
    "@std/http": "jsr:@std/http@^1.0.2",
    "@std/media-types": "jsr:@std/media-types@^1.0.2",
    "@std/path": "jsr:@std/path@^1.0.2",
    "partytown/": "https://deno.land/x/partytown@0.4.8/",
    "preact": "npm:preact@10.23.1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.5",
    "@core/asyncutil": "jsr:@core/asyncutil@^1.0.0",
    "@deco/warp": "jsr:@deco/warp@0.3.3",
    "@std/async": "jsr:@std/async@^0.224.1",
    "@std/datetime": "jsr:@std/datetime@^0.224.0",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/io": "jsr:@std/io@^0.224.4",
    "@std/log": "jsr:@std/log@^0.224.5",
    "@std/semver": "jsr:@std/semver@^0.224.3",
    "@std/streams": "jsr:@std/streams@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@zaubrik/djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "deco/": "./",
    "preact-render-to-string": "npm:preact-render-to-string@6.4.0",
    "std/": "https://deno.land/std@0.203.0/"
  },
  "lock": false,
  "tasks": {
    "check": "deno fmt && deno lint && deno check **/mod.ts",
    "release": "deno run -A jsr:@deco/deco/scripts/release",
    "bundle": "deno run -A jsr:@deco/deco/scripts/bundle",
    "update": "deno run -A jsr:@deco/deco/scripts/update",
    "start": "deno run -A ./scripts/start.ts",
    "new": "deno run -A ./scripts/new.ts"
  },
  "githooks": {
    "pre-commit": "check"
  },
  "exclude": [
    "static",
    "README.md",
    "**/README.md"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "version": "0.54.0"
}
